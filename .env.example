# Local development database. SQLite paths are resolved relative to prisma/schema.prisma.
DATABASE_URL="file:./dev.db"

# Production example for Render with a persistent disk mounted at /opt/render/project/src/storage:
# DATABASE_URL="file:/opt/render/project/src/storage/prod.db"

# Generate a real value before production deploy:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET="replace-with-at-least-32-random-characters"
