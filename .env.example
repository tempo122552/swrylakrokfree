# Supabase Postgres pooled connection string for runtime.
# Example format from Supabase:
# postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1
DATABASE_URL="postgresql://postgres.example:password@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"

# Supabase direct connection string for Prisma migrations.
# Example format from Supabase:
# postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres
DIRECT_URL="postgresql://postgres:password@db.example.supabase.co:5432/postgres"

# Generate a real value before production deploy:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET="replace-with-at-least-32-random-characters"
